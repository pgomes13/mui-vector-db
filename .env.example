# GitHub personal access token — required for reading PRs and posting comments.
# In GitHub Actions this is automatically provided as secrets.GITHUB_TOKEN.
# For local runs: https://github.com/settings/tokens (needs repo + pull_requests scope)
GITHUB_TOKEN=

# Ollama configuration — both are optional.
# OLLAMA_HOST defaults to http://localhost:11434
# OLLAMA_MODEL defaults to qwen2.5-coder:7b
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=qwen2.5-coder:7b
